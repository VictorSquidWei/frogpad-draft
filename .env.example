# FrogPad Draft works with zero configuration — data is saved in your browser.
#
# OPTIONAL: set these to turn on shared, synced data across everyone in the pad
# (one shared pond of tier lists / comps / matchups). Copy this file to ".env",
# fill in the values from your Firebase project, and redeploy.
#
# Firebase console -> Project settings -> "Your apps" -> SDK setup & config.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# Optional extras:
# VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
# VITE_FIREBASE_DOC=shared      # change to keep separate boards (e.g. "scrim-team")
